# Copie para .env na VPS (produção)
# Domínio: https://cashome.avadesk.com.br

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=TROQUE_SENHA_FORTE_POSTGRES
PGDATABASE=financeiro

# OBRIGATÓRIO trocar — não use valores de dev
JWT_SECRET=TROQUE_STRING_LONGA_ALEATORIA
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=TROQUE_SENHA_ADMIN_FORTE

# Porta interna (nginx/caddy faz proxy para esta porta)
PORT=3538

# Domínio público HTTPS (sem barra no final)
APP_URL=https://cashome.avadesk.com.br

# InfinitePay — mesma tag em dev e produção
INFINITEPAY_HANDLE=lucas-rodrigues-740

# InfinitePay Checkout Integrado (cadastrar no app):
#   URL do site: https://cashome.avadesk.com.br
# Webhook automático: https://cashome.avadesk.com.br/api/payments/webhook
# Redirect pós-pagamento: https://cashome.avadesk.com.br/app/perfil?checkout=success
