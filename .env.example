PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-postgres-password
PGDATABASE=financeiro
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
PORT=3001

# --- App ---
# URL pública onde o app roda.
# Dev:   http://localhost:3538  (ou porta do PORT)
# Produção: https://cashome.avadesk.com.br  (ver .env.production.example)
APP_URL=http://localhost:3001

# --- InfinitePay (plano Pro + PDF) ---
# InfiniteTag sem $. Ex.: lucas-rodrigues-740
# App InfinitePay → Vendas → Checkout → cadastre a URL do APP_URL
# Webhook produção: https://cashome.avadesk.com.br/api/payments/webhook
INFINITEPAY_HANDLE=lucas-rodrigues-740

# --- Suporte (footer / contato) ---
SUPPORT_WHATSAPP=38998100827
SUPPORT_EMAIL=lucasrodrigues4@live.com

# --- Relatório IA (Gemini) ---
# Chave em: https://aistudio.google.com/apikey
# Sem chave: PDF funciona com gráficos, mas análise usa texto fixo (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Resend (e-mail) ---
# Chave em: https://resend.com/api-keys
RESEND_API_KEY=
# Remetente verificado no Resend (teste: onboarding@resend.dev)
RESEND_FROM=Home Finanças <onboarding@resend.dev>
