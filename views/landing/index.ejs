<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/landing-head') %>
  <title>Home Finanças — Seu mês em um painel</title>
</head>
<body class="min-h-dvh">
  <a href="#conteudo" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[10px] focus:bg-ice focus:px-4 focus:py-2 focus:text-ice-ink">
    Ir para o conteúdo
  </a>

  <header id="landingNav" class="sticky top-0 z-20 transition-colors duration-180" style="transition-timing-function: var(--ease-out-quart);">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
      <a href="/" class="flex items-center gap-3" aria-label="Home Finanças — início">
        <%- include('../partials/brand-logo', { logoSize: 'sm' }) %>
      </a>
      <nav class="flex items-center gap-3" aria-label="Navegação principal">
        <a href="/login" class="btn-ghost hidden px-4 py-2 sm:inline-flex">Entrar</a>
        <a href="#adquirir" data-scroll-acquire class="btn-ice px-4 py-2 text-sm sm:px-6 sm:py-3">Adquirir</a>
      </nav>
    </div>
  </header>

  <main id="conteudo">
    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-5 pb-16 pt-10 sm:px-8 sm:pb-24 sm:pt-16 lg:pb-28">
      <div class="landing-reveal is-visible max-w-xl">
        <%- include('../partials/brand-logo', { logoSize: 'hero' }) %>

        <h1 class="mt-6 font-display text-balance text-[clamp(2rem,5vw,3.75rem)] font-bold leading-[1.08] tracking-[-0.03em] text-text sm:mt-8">
          Planilha no fim do mês? Nem pensar.
        </h1>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="#adquirir" data-scroll-acquire class="btn-ice w-full sm:w-auto">Adquirir acesso</a>
          <a href="/login" class="btn-ghost w-full sm:w-auto">Já tenho conta</a>
        </div>
      </div>
    </section>

    <!-- Showcase -->
    <section class="landing-showcase" aria-labelledby="showcase-titulo">
      <div class="landing-showcase-inner px-5 text-center sm:px-8">
        <h2 id="showcase-titulo" class="sr-only">Preview do painel</h2>
        <div class="landing-reveal min-w-0">
          <%- include('../partials/landing/screenshot-slot', {
            src: typeof shots !== 'undefined' ? shots.dashboard : null,
            alt: 'Dashboard Home Finanças — saldo, receitas e despesas',
            fallbackPartial: 'mock-bento'
          }) %>
        </div>
        <p class="landing-showcase-caption landing-reveal mt-6 text-sm font-normal text-muted-2">
          Saldo, receitas e despesas no mesmo olhar — valores abaixo são fictícios para demonstração.
        </p>
      </div>
    </section>

    <!-- Pricing & access -->
    <% if (typeof pricing !== 'undefined' && pricing) { %>
    <section id="adquirir" class="landing-pricing border-t border-border" aria-labelledby="preco-titulo">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
        <div class="landing-reveal landing-pricing-card mx-auto max-w-2xl rounded-[14px] border border-border bg-surface px-6 py-8 sm:px-10 sm:py-12">
          <div class="text-center">
            <p class="font-mono text-[clamp(2.5rem,6vw,3.5rem)] font-semibold tabular-nums tracking-tight text-text">
              <%= pricing.priceShort %>
            </p>
            <p id="preco-titulo" class="mt-2 font-display text-lg font-semibold text-text">
              <%= pricing.accessDays %> dias de acesso ao painel
            </p>
            <p class="mt-2 text-sm text-muted">Acesso pago obrigatório — renove no perfil quando expirar.</p>
          </div>

          <div class="mt-10">
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wide text-muted-2">Formas de pagamento</h3>
              <div class="mt-3 flex flex-wrap gap-2">
                <% pricing.paymentMethods.forEach(function(method) { %>
                <span class="landing-pricing-pill"><%= method %></span>
                <% }); %>
              </div>
              <p class="mt-3 text-sm text-muted">Pagamento seguro via InfinitePay</p>
            </div>
          </div>

          <ul class="mt-10 space-y-2 border-t border-border pt-8 text-sm text-muted">
            <li>Dashboard completo — receitas, despesas, parcelas e orçamentos</li>
            <li>Relatório PDF do mês</li>
            <li>Previsão de saldo e alertas</li>
            <li>PWA no celular</li>
          </ul>

          <form id="acquireForm" class="landing-acquire-form" novalidate>
            <div class="landing-acquire-field">
              <label for="acquireNome">Nome completo</label>
              <input id="acquireNome" name="nome" type="text" required autocomplete="name" placeholder="Seu nome">
            </div>
            <div class="landing-acquire-field">
              <label for="acquireEmail">E-mail</label>
              <input id="acquireEmail" name="email" type="email" required autocomplete="email" placeholder="voce@email.com">
            </div>
            <p id="acquireError" class="landing-acquire-error" hidden role="alert"></p>
            <div class="landing-acquire-actions">
              <button type="submit" id="acquireSubmit" class="btn-ice w-full sm:w-auto" data-label="Adquirir — <%= pricing.priceShort %>">
                Adquirir — <%= pricing.priceShort %>
              </button>
              <a href="/login" class="landing-acquire-link">Já tenho conta</a>
            </div>
          </form>
        </div>
      </div>
    </section>
    <% } %>
  </main>

  <footer class="border-t border-border">
    <div class="mx-auto max-w-6xl px-5 py-8 sm:px-8">
      <%- include('../partials/support-contact', { variant: 'landing' }) %>
      <div class="landing-footer-meta">
        <a href="/login" class="landing-footer-login">Entrar</a>
      </div>
    </div>
  </footer>

  <script src="/js/landing.js"></script>
  <script src="/js/landing-checkout.js"></script>
</body>
</html>
