<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/landing-head') %>
  <title>Home Finanças — Controle pessoal sem planilha</title>
</head>
<body class="min-h-dvh">
  <a href="#conteudo" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[10px] focus:bg-ice focus:px-4 focus:py-2 focus:text-ice-ink">
    Ir para o conteúdo
  </a>

  <header id="landingNav" class="sticky top-0 z-20 transition-colors duration-180" style="transition-timing-function: var(--ease-out-quart);">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
      <a href="/" class="flex items-center gap-3" aria-label="Home Finanças — início">
        <%- include('../partials/brand-logo', { logoSize: 'sm' }) %>
      </a>
      <nav class="flex items-center gap-3" aria-label="Navegação principal">
        <a href="/login" class="btn-ghost hidden px-4 py-2 sm:inline-flex">Entrar</a>
        <a href="/login" class="btn-ice px-4 py-2 text-sm sm:px-6 sm:py-3">Acessar painel</a>
      </nav>
    </div>
  </header>

  <main id="conteudo">
    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-5 pb-16 pt-10 sm:px-8 sm:pb-24 sm:pt-16 lg:pb-28">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="landing-reveal max-w-xl">
          <%- include('../partials/brand-logo', { logoSize: 'hero' }) %>

          <h1 class="mt-6 font-display text-balance text-[clamp(2rem,5vw,3.75rem)] font-bold leading-[1.08] tracking-[-0.03em] text-text sm:mt-8">
            Suas finanças. Um painel. Zero planilha.
          </h1>
          <p class="mt-5 max-w-[55ch] text-pretty text-base leading-relaxed text-muted sm:text-lg">
            Receitas, despesas, parcelas e previsão do mês — persistidos entre sessões, legíveis à noite, confiáveis no fim do mês.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a href="/login" class="btn-ice w-full sm:w-auto">Acessar meu painel</a>
            <a href="/login" class="btn-ghost w-full sm:w-auto">Já tenho conta</a>
          </div>
        </div>

        <!-- Product mock -->
        <div class="landing-reveal" style="transition-delay: 80ms;">
          <div class="relative rounded-[14px] border border-border bg-surface p-5 shadow-[0_24px_80px_oklch(0_0_0_/_0.45)] sm:p-6" aria-hidden="true">
            <div class="mb-4 flex items-center justify-between gap-3">
              <span class="font-mono text-xs text-muted-2">jul/2026</span>
              <span class="rounded-full bg-surface-2 px-2.5 py-1 font-mono text-[11px] text-muted">Dashboard</span>
            </div>

            <div class="grid gap-3 sm:grid-cols-[1.4fr_1fr]">
              <!-- Hero balance -->
              <div class="relative overflow-hidden rounded-[14px] border border-border bg-surface-2 p-4 sm:p-5">
                <div class="absolute inset-y-3 left-0 w-[3px] rounded-r bg-green"></div>
                <p class="text-xs text-muted">Saldo do mês</p>
                <p class="mt-1 font-display text-[clamp(1.5rem,4vw,2.25rem)] font-bold tabular-nums tracking-tight text-green">
                  R$&nbsp;4.280,50
                </p>
                <p class="mt-2 font-mono text-[11px] text-muted-2">+12% vs mês anterior</p>
              </div>

              <!-- Mini KPIs -->
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-1">
                <div class="relative rounded-[10px] border border-border bg-surface-2 px-3 py-2.5">
                  <div class="absolute inset-y-2 left-0 w-[2px] rounded-r bg-ice"></div>
                  <p class="text-[11px] text-muted">Receitas</p>
                  <p class="font-mono text-sm font-semibold tabular-nums text-text">R$&nbsp;8.400</p>
                </div>
                <div class="relative rounded-[10px] border border-border bg-surface-2 px-3 py-2.5">
                  <div class="absolute inset-y-2 left-0 w-[2px] rounded-r bg-red"></div>
                  <p class="text-[11px] text-muted">Despesas</p>
                  <p class="font-mono text-sm font-semibold tabular-nums text-text">R$&nbsp;4.119</p>
                </div>
                <div class="relative rounded-[10px] border border-border bg-surface-2 px-3 py-2.5">
                  <div class="absolute inset-y-2 left-0 w-[2px] rounded-r bg-amber"></div>
                  <p class="text-[11px] text-muted">Pendente</p>
                  <p class="font-mono text-sm font-semibold tabular-nums text-text">R$&nbsp;890</p>
                </div>
              </div>
            </div>

            <!-- Progress -->
            <div class="mt-4 rounded-[10px] border border-border bg-surface-2 p-4">
              <div class="flex items-baseline justify-between gap-2">
                <p class="text-xs text-muted">Contas pagas este mês</p>
                <p class="font-mono text-xs tabular-nums text-text">68%</p>
              </div>
              <div class="mt-2 h-1.5 overflow-hidden rounded-full bg-ice-dim">
                <div class="h-full w-[68%] rounded-full bg-ice"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits — asymmetric, not card grid -->
    <section class="border-t border-border bg-surface/40" aria-labelledby="beneficios-titulo">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
        <h2 id="beneficios-titulo" class="landing-reveal font-display text-balance text-[clamp(1.5rem,3vw,2rem)] font-bold tracking-[-0.02em]">
          Tudo o que a planilha promete — sem a planilha.
        </h2>

        <div class="mt-12 space-y-0 divide-y divide-border">
          <article class="landing-reveal grid gap-4 py-8 sm:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] sm:gap-12 sm:py-10">
            <h3 class="font-display text-xl font-semibold text-text">Saldo do mês em um olhar</h3>
            <p class="max-w-prose text-pretty leading-relaxed text-muted">
              Bento com saldo hero, receitas, despesas e pendências — números tabulares, legíveis no escuro, sem abrir dez abas.
            </p>
          </article>

          <article class="landing-reveal grid gap-4 py-8 sm:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] sm:gap-12 sm:py-10">
            <p class="order-2 max-w-prose text-pretty leading-relaxed text-muted sm:order-1 sm:col-start-1">
              Cadastre parcelas e empréstimos uma vez. O painel lembra vencimentos, mostra o que falta pagar e evita surpresa no cartão.
            </p>
            <h3 class="order-1 font-display text-xl font-semibold text-text sm:order-2 sm:col-start-2 sm:text-right">
              Parcelas e empréstimos no radar
            </h3>
          </article>

          <article class="landing-reveal grid gap-4 py-8 sm:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] sm:gap-12 sm:py-10">
            <h3 class="font-display text-xl font-semibold text-text">Previsão antes de fechar o mês</h3>
            <p class="max-w-prose text-pretty leading-relaxed text-muted">
              Veja projeção de saldo com base no que já entrou, no que falta pagar e no que está agendado — antes de estourar o orçamento.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24" aria-labelledby="cta-final">
      <div class="landing-reveal rounded-[14px] border border-border bg-surface px-6 py-10 sm:px-10 sm:py-14">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
          <div class="max-w-lg">
            <h2 id="cta-final" class="font-display text-balance text-[clamp(1.375rem,3vw,1.75rem)] font-bold tracking-[-0.02em]">
              Pare de adivinhar quanto sobrou.
            </h2>
            <p class="mt-2 text-pretty text-muted">
              Entre no painel, marque pagamentos e acompanhe o mês com clareza.
            </p>
          </div>
          <a href="/login" class="btn-ice shrink-0 self-start sm:self-center">Acessar meu painel</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-border">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between sm:px-8">
      <p>Home Finanças · controle pessoal · PWA instalável</p>
      <a href="/login" class="font-medium text-text underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ice focus-visible:ring-offset-2 focus-visible:ring-offset-bg">
        Entrar
      </a>
    </div>
  </footer>

  <script src="/js/landing.js"></script>
</body>
</html>
