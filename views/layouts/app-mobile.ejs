<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/head') %>
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Home Finanças</title>
</head>
<body class="layout-mobile-bank" data-page="<%= page %>">
  <div class="app app-mobile-shell">
    <header class="mobile-header">
      <div class="mobile-header-top">
        <a href="/app/dashboard" class="mobile-brand" aria-label="Home Finanças — ir ao dashboard">
          <%- include('../partials/brand-logo', { logoSize: 'sm' }) %>
        </a>
        <div class="month-switcher month-switcher-compact" role="group" aria-label="Navegação por mês">
          <button type="button" onclick="changeMonth(-1)" aria-label="Mês anterior">‹</button>
          <span class="label mono" id="monthLabel" aria-live="polite">—</span>
          <button type="button" onclick="changeMonth(1)" aria-label="Próximo mês">›</button>
        </div>
        <button type="button" class="icon-btn mobile-logout" id="logoutBtn" aria-label="Sair">⎋</button>
      </div>
      <%- include('../partials/hero-balance') %>
    </header>

    <main id="view" class="mobile-main" role="main" aria-busy="true">
      <div class="loading-state">Carregando…</div>
    </main>
  </div>

  <%- include('../partials/bottom-nav', { page }) %>

  <dialog class="modal comprovante-dialog" id="comprovanteDialog" aria-labelledby="comprovanteDialogTitle">
    <div class="modal-inner comprovante-dialog-inner">
      <div class="comprovante-dialog-head">
        <h3 id="comprovanteDialogTitle">Comprovante</h3>
        <button type="button" class="icon-btn" onclick="closeComprovanteDialog()" aria-label="Fechar">✕</button>
      </div>
      <div id="comprovanteDialogBody" class="comprovante-dialog-body"></div>
      <div class="comprovante-dialog-actions">
        <button type="button" class="btn btn-ghost" id="comprovanteDownloadPdfBtn" onclick="baixarComprovantePdf()">Baixar PDF</button>
        <button type="button" class="btn btn-primary" onclick="closeComprovanteDialog()">Fechar</button>
      </div>
    </div>
  </dialog>

  <dialog class="modal modal-launch" id="modalDialog" aria-labelledby="modalTitle">
    <div class="modal-inner">
      <div id="modalBody" class="modal-body"></div>
    </div>
  </dialog>

  <dialog class="modal modal-confirm" id="confirmDialog" aria-labelledby="confirmTitle" aria-describedby="confirmMessage">
    <div class="modal-inner">
      <h3 id="confirmTitle">Confirmar</h3>
      <p class="modal-confirm-msg" id="confirmMessage"></p>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="confirmCancel">Cancelar</button>
        <button type="button" class="btn btn-primary" id="confirmOk">Confirmar</button>
      </div>
    </div>
  </dialog>

  <dialog class="modal modal-confirm" id="passwordDialog" aria-labelledby="passwordTitle" aria-describedby="passwordMessage">
    <div class="modal-inner">
      <h3 id="passwordTitle">Confirmar senha</h3>
      <p class="modal-confirm-msg" id="passwordMessage"></p>
      <div class="field password-dialog-field">
        <label for="passwordDialogInput">Senha</label>
        <input id="passwordDialogInput" type="password" autocomplete="current-password" placeholder="Digite sua senha">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="passwordCancel">Cancelar</button>
        <button type="button" class="btn btn-primary" id="passwordOk">Confirmar</button>
      </div>
    </div>
  </dialog>

  <div class="toast-container toast-container-mobile" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/ui.js"></script>
  <script src="/js/charts.js"></script>
  <script src="/js/app.js?v=26"></script>
  <%- include('../partials/sw-register') %>
</body>
</html>
