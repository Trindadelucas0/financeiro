<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/head') %>
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Home Finanças</title>
</head>
<body class="layout-desktop<%= page === 'perfil' ? ' page-perfil' : '' %>" data-page="<%= page %>">
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a href="/app/dashboard" class="brand-logo-link" aria-label="Home Finanças — ir ao dashboard">
          <%- include('../partials/brand-logo') %>
        </a>
      </div>
      <div class="actions-row">
        <% if (page !== 'perfil') { %>
        <button type="button" class="btn btn-primary btn-sm" onclick="openModal()">+ Novo lançamento</button>
        <button type="button" class="btn btn-ghost btn-sm" onclick="exportPDF()">Relatório PDF</button>
        <a href="/app/previsao" class="btn btn-ghost btn-sm">Previsão</a>
        <% } %>
        <a href="/app/perfil" class="btn btn-ghost btn-sm profile-link-btn" id="profileLink" hidden>
          <span class="profile-link-avatar" id="profileLinkAvatar" aria-hidden="true">•</span>
          <span id="profileLinkLabel">Perfil</span>
        </a>
        <a href="/admin/users" class="btn btn-ghost btn-sm" id="adminLink" hidden>Admin</a>
        <a href="/admin/clients" class="btn btn-ghost btn-sm" id="adminClientsLink" hidden>Clientes</a>
        <button type="button" class="btn btn-ghost btn-sm" id="logoutBtn">Sair</button>
      </div>
      <a href="/app/perfil" class="topbar-mobile-profile" id="topbarMobileProfile" aria-label="Minha conta">
        <span class="profile-link-avatar" id="topbarMobileAvatar">•</span>
      </a>
      <% if (page !== 'perfil') { %>
      <div class="month-switcher" role="group" aria-label="Navegação por mês">
        <button type="button" onclick="changeMonth(-1)" aria-label="Mês anterior">‹</button>
        <span class="label mono" id="monthLabel" aria-live="polite">—</span>
        <button type="button" onclick="changeMonth(1)" aria-label="Próximo mês">›</button>
      </div>
      <% } %>
    </header>

    <div id="renewalTopbar" class="renewal-topbar" hidden aria-live="polite"></div>

    <% if (page !== 'perfil') { %>
    <nav class="tabs desktop-tabs" role="tablist" aria-label="Seções do painel">
      <a href="/app/dashboard" class="tab<%= page === 'dashboard' ? ' active' : '' %>" role="tab"<%= page === 'dashboard' ? ' aria-current="page"' : '' %>>Dashboard</a>
      <a href="/app/receitas" class="tab<%= page === 'receitas' ? ' active' : '' %>" role="tab"<%= page === 'receitas' ? ' aria-current="page"' : '' %>>Receitas</a>
      <a href="/app/despesas" class="tab<%= page === 'despesas' ? ' active' : '' %>" role="tab"<%= page === 'despesas' ? ' aria-current="page"' : '' %>>Despesas</a>
      <a href="/app/compromissos" class="tab<%= page === 'compromissos' ? ' active' : '' %>" role="tab"<%= page === 'compromissos' ? ' aria-current="page"' : '' %>>Parcelas &amp; Empréstimos</a>
      <a href="/app/orcamentos" class="tab<%= page === 'orcamentos' ? ' active' : '' %>" role="tab"<%= page === 'orcamentos' ? ' aria-current="page"' : '' %>>Orçamentos</a>
      <a href="/app/previsao" class="tab<%= page === 'previsao' ? ' active' : '' %>" role="tab"<%= page === 'previsao' ? ' aria-current="page"' : '' %>>Previsão</a>
    </nav>

    <div class="mobile-only">
      <div class="mobile-tip-banner" id="mobileTipBanner" hidden role="status">
        <p>Use o menu <strong>Mais</strong> para Parcelas, Orçamentos, Previsão e PDF.</p>
        <button type="button" class="mobile-tip-dismiss" id="mobileTipDismiss" aria-label="Fechar dica">×</button>
      </div>
      <%- include('../partials/hero-balance') %>
    </div>
    <% } %>

    <main id="view" role="main" aria-busy="true">
      <div class="loading-state">Carregando…</div>
    </main>

  <footer class="app-footer">
    <%- include('../partials/support-contact') %>
    <% if (page !== 'perfil') { %>
    <p class="footer-note footer-note--tech desktop-only">
      Dados sincronizados com sua conta. Comprovantes em base64 — evite arquivos grandes.
      Empréstimos usam juros simplificado (não é Price/SAC).
    </p>
    <% } %>
  </footer>
  </div>

  <%- include('../partials/bottom-nav', { page }) %>

  <% if (page !== 'perfil') { %>
  <button type="button" class="fab-mobile mobile-only" onclick="openModal()" aria-label="Novo lançamento">+</button>

  <dialog class="modal mais-sheet" id="maisSheetDialog" aria-labelledby="maisSheetTitle">
    <div class="modal-inner">
      <div class="modal-grab" aria-hidden="true"></div>
      <h3 id="maisSheetTitle" class="mais-sheet-title">Mais opções</h3>
      <nav class="mais-sheet-list" aria-label="Seções adicionais">
        <a href="/app/compromissos" class="mais-sheet-item">
          <span class="mais-sheet-icon" aria-hidden="true">⧉</span>
          <span class="mais-sheet-body">
            <strong>Parcelas &amp; Empréstimos</strong>
            <span>Contratos, parcelas do mês e progresso</span>
          </span>
        </a>
        <a href="/app/orcamentos" class="mais-sheet-item">
          <span class="mais-sheet-icon" aria-hidden="true">◎</span>
          <span class="mais-sheet-body">
            <strong>Orçamentos &amp; Saldo</strong>
            <span>Tetos por categoria e saldo em conta</span>
          </span>
        </a>
        <a href="/app/previsao" class="mais-sheet-item">
          <span class="mais-sheet-icon" aria-hidden="true">↗</span>
          <span class="mais-sheet-body">
            <strong>Previsão</strong>
            <span>Projeção dos próximos 12 meses</span>
          </span>
        </a>
        <button type="button" class="mais-sheet-item" onclick="exportPDF(); FinanceUI.closeMaisSheet();">
          <span class="mais-sheet-icon" aria-hidden="true">↓</span>
          <span class="mais-sheet-body">
            <strong>Relatório PDF</strong>
            <span>Baixar relatório do mês atual</span>
          </span>
        </button>
      </nav>
      <button type="button" class="btn btn-ghost btn-block mais-sheet-close" id="maisSheetClose">Fechar</button>
    </div>
  </dialog>

  <dialog class="modal saldo-sheet" id="saldoSheetDialog" aria-labelledby="saldoSheetTitle">
    <div class="modal-inner saldo-sheet-inner">
      <div class="modal-grab" aria-hidden="true"></div>
      <h3 id="saldoSheetTitle" class="saldo-sheet-title">Saldo em conta</h3>
      <p class="saldo-sheet-desc" id="saldoSheetDesc"></p>
      <p class="saldo-sheet-preview mono" id="saldoSheetPreview" hidden></p>
      <form id="saldoSheetForm" class="saldo-sheet-form">
        <div class="field saldo-sheet-field">
          <label for="saldoSheetValor" id="saldoSheetValorLabel" class="saldo-sheet-label">Valor</label>
          <div class="saldo-sheet-value-wrap">
            <span class="saldo-sheet-currency mono" aria-hidden="true">R$</span>
            <input id="saldoSheetValor" class="saldo-sheet-value-input mono" type="text" inputmode="decimal" autocomplete="off" placeholder="0,00" required>
          </div>
        </div>
        <div class="field saldo-sheet-field" id="saldoSheetDescricaoField" hidden>
          <label for="saldoSheetDescricao" class="saldo-sheet-label">Descrição (opcional)</label>
          <input id="saldoSheetDescricao" class="saldo-sheet-desc-input" type="text" placeholder="Ex.: Salário, PIX, transferência" maxlength="80">
        </div>
        <div class="saldo-sheet-actions">
          <button type="submit" class="btn btn-primary btn-block" id="saldoSheetSubmit">Salvar</button>
          <button type="button" class="btn btn-ghost btn-block" id="saldoSheetCancel">Cancelar</button>
        </div>
      </form>
    </div>
  </dialog>

  <dialog class="modal modal-launch" id="modalDialog" aria-labelledby="modalTitle">
    <div class="modal-inner">
      <div id="modalBody" class="modal-body"></div>
    </div>
  </dialog>
  <% } %>

  <dialog class="modal modal-confirm" id="confirmDialog" aria-labelledby="confirmTitle" aria-describedby="confirmMessage">
    <div class="modal-inner">
      <h3 id="confirmTitle">Confirmar</h3>
      <p class="modal-confirm-msg" id="confirmMessage"></p>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="confirmCancel">Cancelar</button>
        <button type="button" class="btn btn-primary" id="confirmOk">Confirmar</button>
      </div>
    </div>
  </dialog>

  <dialog class="modal modal-confirm" id="passwordDialog" aria-labelledby="passwordTitle" aria-describedby="passwordMessage">
    <div class="modal-inner">
      <h3 id="passwordTitle">Confirmar senha</h3>
      <p class="modal-confirm-msg" id="passwordMessage"></p>
      <div class="field password-dialog-field">
        <label for="passwordDialogInput">Senha</label>
        <input id="passwordDialogInput" type="password" autocomplete="current-password" placeholder="Digite sua senha">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="passwordCancel">Cancelar</button>
        <button type="button" class="btn btn-primary" id="passwordOk">Confirmar</button>
      </div>
    </div>
  </dialog>

  <dialog class="modal auth-welcome-dialog" id="dailyGreetingDialog" aria-labelledby="dailyGreetingTitle" aria-describedby="dailyGreetingSubtitle">
    <div class="modal-inner">
      <h3 id="dailyGreetingTitle"></h3>
      <p class="modal-confirm-msg" id="dailyGreetingSubtitle">Que bom ter você de volta.</p>
      <div class="modal-actions">
        <button type="button" class="btn btn-primary" id="dailyGreetingOk">Continuar</button>
      </div>
    </div>
  </dialog>

  <div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/dailyGreeting.js"></script>
  <script src="/js/pwa.js"></script>
  <script src="/js/pushNotifications.js"></script>
  <script src="/js/renewalReminder.js"></script>
  <% if (page !== 'perfil') { %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/ui.js"></script>
  <script src="/js/charts.js"></script>
  <script src="/js/app.js"></script>
  <% } else { %>
  <script src="/js/perfil.js"></script>
  <% } %>
  <%- include('../partials/sw-register') %>
</body>
</html>
