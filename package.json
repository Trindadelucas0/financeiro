{
  "name": "painel-financeiro",
  "version": "1.0.0",
  "description": "Painel financeiro pessoal — Express + PostgreSQL multi-tenant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/dev.js",
    "migrate": "node src/db/migrate.js",
    "build:css": "tailwindcss -i ./src/styles/landing.css -o ./public/css/landing.css --minify",
    "dev:css": "tailwindcss -i ./src/styles/landing.css -o ./public/css/landing.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11"
  }
}
