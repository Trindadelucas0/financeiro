{
  "name": "painel-financeiro",
  "version": "1.0.0",
  "description": "Painel financeiro pessoal — Express + PostgreSQL multi-tenant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/dev.js",
    "migrate": "node src/db/migrate.js",
    "test:payments": "node scripts/test-payments.js",
    "test:admin-clients": "node scripts/test-admin-clients.js",
    "test:production": "node scripts/test-production.js",
    "test:notifications": "node scripts/test-notifications.js",
    "test:greetings": "node scripts/test-greetings.js",
    "notify:send": "node scripts/send-notifications.js",
    "notify:greetings": "node scripts/send-greeting-notifications.js",
    "build:css": "tailwindcss -i ./src/styles/landing.css -o ./public/css/landing.css --minify",
    "generate:landing-shots": "node scripts/generate-landing-shots.js",
    "build:icons": "node scripts/generate-pwa-icons.js",
    "dev:css": "tailwindcss -i ./src/styles/landing.css -o ./public/css/landing.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.11"
  }
}
